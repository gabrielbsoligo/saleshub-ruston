{
  "manifest_version": 3,
  "name": "SalesHub - MKTLAB Importer",
  "version": "1.0.0",
  "description": "Importa leads do MKTLAB CRM para o SalesHub em lote",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://mktlab.app/*",
    "https://iaompeiokjxbffwehhrx.supabase.co/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://mktlab.app/crm/leads*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "SalesHub Importer"
  }
}
